// Cluster CI Cache website — TetherScript HTTP server.
// Run: tetherscript run --grant-fs . server.tether

fn content_type(path) {
    if path.ends_with(".html") { return "text/html; charset=utf-8" }
    if path.ends_with(".css") { return "text/css; charset=utf-8" }
    if path.ends_with(".js") { return "application/javascript; charset=utf-8" }
    if path.ends_with(".json") { return "application/json" }
    if path.ends_with(".txt") { return "text/plain; charset=utf-8" }
    if path.ends_with(".svg") { return "image/svg+xml" }
    if path.ends_with(".ico") { return "image/x-icon" }
    if path.ends_with(".png") { return "image/png" }
    return "application/octet-stream"
}

fn response(status, body, content_type_value) {
    let resp = map()
    resp.status = status
    resp.body = body
    let headers = map()
    headers["content-type"] = content_type_value
    resp.headers = headers
    return resp
}

fn html_resp(status, body) { return response(status, body, "text/html; charset=utf-8") }
fn text_resp(status, body) { return response(status, body, "text/plain; charset=utf-8") }

fn card(icon, title, desc) {
    return "<div class='rounded-xl border border-white/10 bg-white/5 p-6 transition hover:border-white/20 hover:bg-white/10'>" +
        "<div class='text-3xl mb-3'>" + icon + "</div>" +
        "<h3 class='text-base font-semibold text-white mb-2'>" + title + "</h3>" +
        "<p class='text-sm text-slate-400 leading-relaxed'>" + desc + "</p></div>"
}

fn stat(num, label) {
    return "<div class='rounded-xl border border-white/10 bg-white/5 p-5 text-center'>" +
        "<div class='text-2xl font-extrabold bg-gradient-to-r from-orange-400 to-purple-400 bg-clip-text text-transparent'>" + num + "</div>" +
        "<div class='mt-1 text-xs text-slate-500 uppercase tracking-wider'>" + label + "</div></div>"
}

fn badge(dot, text) {
    return "<span class='inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-slate-300'>" +
        "<span class='h-2 w-2 rounded-full " + dot + "'></span>" + text + "</span>"
}

fn code_block(lines) {
    let mut html = "<div class='rounded-xl border border-white/10 bg-black/40 overflow-hidden my-4'><pre class='p-4 overflow-x-auto text-sm text-slate-300 font-mono leading-relaxed'>"
    for line in lines {
        html = html + line + "\n"
    }
    html = html + "</pre></div>"
    return html
}

fn cmt(text) {
    return "<span class='text-slate-500'>" + text + "</span>"
}
fn page(version, github_url, release_url) {
    return "<!doctype html><html lang='en' class='scroll-smooth'>" +
        "<head>" +
        "<meta charset='UTF-8'>" +
        "<meta name='viewport' content='width=device-width, initial-scale=1.0'>" +
        "<title>Cluster CI Cache — In-Cluster Build Cache for Kubernetes</title>" +
        "<meta name='description' content='Fast, secure, deduplicated build caching for Rust, npm/pnpm/yarn, and Docker/BuildKit — native to Kubernetes.'>" +
        "<script src='https://cdn.tailwindcss.com'></script>" +
        "<style>body{background:radial-gradient(circle at 20% 0%,rgba(222,165,132,.12),transparent 32rem),radial-gradient(circle at 85% 15%,rgba(188,140,255,.10),transparent 28rem),#0d1117}</style>" +
        "</head>" +
        "<body class='min-h-screen text-slate-100 antialiased'>" +
        hero(version, github_url, release_url) +
        badges_section() +
        problem_section() +
        features_section() +
        types_section() +
        quickstart_section() +
        stats_section() +
        metrics_section() +
        footer_section(github_url, release_url, version) +
        "</body></html>"
}

fn hero(version, github_url, release_url) {
    return "<section class='text-center pt-24 pb-12 px-6'>" +
        "<h1 class='text-5xl font-bold mb-4'>🚀 <span class='bg-gradient-to-r from-orange-400 via-pink-400 to-purple-400 bg-clip-text text-transparent'>Cluster CI Cache</span></h1>" +
        "<p class='text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed'>Fast, secure, deduplicated build caching for Rust, npm/pnpm/yarn, and Docker/BuildKit — native to Kubernetes, boring to operate.</p>" +
        install_command() +
        "<div class='flex flex-wrap gap-3 justify-center mt-6'>" +
        "<a href='" + release_url + "' class='px-7 py-3 rounded-xl bg-green-500 hover:bg-green-400 text-white font-semibold transition hover:-translate-y-0.5'>⬇ Download v" + version + "</a>" +
        "<a href='" + github_url + "' class='px-7 py-3 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 text-slate-200 font-semibold transition hover:-translate-y-0.5'>📖 GitHub</a>" +
        "</div></section>"
}

