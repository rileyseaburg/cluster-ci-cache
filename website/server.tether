        "<div class='rounded-xl border border-green-500/30 bg-green-500/5 overflow-hidden mb-4'>" +
        "<div class='px-4 py-2 border-b border-green-500/20 text-xs text-green-500 font-semibold uppercase tracking-wider'>1. Install the CLI</div>" +
        "<pre class='p-4 overflow-x-auto text-sm text-green-400 font-mono leading-relaxed'>" +
        "curl -fsSL https://github.com/rileyseaburg/cluster-ci-cache/releases/latest/download/install.sh | bash\n" +
        "</pre></div>" +
        "<div class='rounded-xl border border-white/10 bg-black/40 overflow-hidden mb-4'>" +
        "<div class='px-4 py-2 border-b border-white/10 text-xs text-slate-500 font-semibold uppercase tracking-wider'>2. Deploy to Kubernetes</div>" +
        "<pre class='p-4 overflow-x-auto text-sm text-slate-300 font-mono leading-relaxed'>" +
        "kubectl apply -k deploy/k8s/\n" +
        "</pre></div>" +
        "<div class='rounded-xl border border-white/10 bg-black/40 overflow-hidden mb-4'>" +
        "<div class='px-4 py-2 border-b border-white/10 text-xs text-slate-500 font-semibold uppercase tracking-wider'>3. Use in CI</div>" +
        "<pre class='p-4 overflow-x-auto text-sm text-slate-300 font-mono leading-relaxed'>" +
        cmt("&gt; Restore cache") + "\n" +
        "ci-cache restore --cache-type cargo \\\n" +
        "  --key cargo-$LOCK_HASH \\\n" +
        "  --paths ~/.cargo/registry,~/.cargo/git,target\n\n" +
        "cargo build --release\n\n" +
        cmt("&gt; Save cache") + "\n" +
        "ci-cache save --cache-type cargo \\\n" +
        "  --key cargo-$LOCK_HASH \\\n" +
        "  --paths ~/.cargo/registry,~/.cargo/git,target\n" +
        "</pre></div>" +
        "<div class='rounded-xl border border-white/10 bg-black/40 overflow-hidden'>" +
        "<div class='px-4 py-2 border-b border-white/10 text-xs text-slate-500 font-semibold uppercase tracking-wider'>Docker image</div>" +
        "<pre class='p-4 overflow-x-auto text-sm text-slate-300 font-mono leading-relaxed'>" +
        "docker pull registry.quantum-forge.net/cluster-ci-cache/ci-cache:v0.1.0\n" +
        "</pre></div>" +
        "</div></section>"
}

