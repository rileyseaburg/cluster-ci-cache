        card("🦀", "Rust / Cargo", "~/.cargo/registry, ~/.cargo/git, optional target/. Keyed on Cargo.lock hash.") +
        card("📦", "npm", "~/.npm cache. Keyed on package-lock.json hash.") +
        card("📦", "pnpm", "pnpm content-addressable store. Keyed on pnpm-lock.yaml hash.") +
        card("🧶", "yarn", "yarn cache directory. Keyed on yarn.lock hash.") +
        card("🐳", "Docker / BuildKit", "BuildKit registry-type cache. CLI helpers generate --cache-from/--cache-to flags.") +
        card("📁", "Generic", "Any arbitrary directory. Custom toolchains, LLVM artifacts, etc.") +
        "</div></div></section>"
}

fn quickstart_section() {
